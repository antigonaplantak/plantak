{
  "name": "api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "E2E_BYPASS_AUTH=1 jest --config test/jest-e2e.json",
    "check:shell": "bash -n scripts/pre_change_safety.sh && bash -n scripts/smoke_bookings_regression.sh && bash -n scripts/booking_gate_one_shot.sh",
    "smoke:bookings": "bash scripts/smoke_bookings_regression.sh",
    "gate:bookings": "bash scripts/booking_gate_one_shot.sh",
    "load:availability": "node scripts/load_availability_gate.mjs",
    "queue:smoke": "node scripts/queue_smoke.mjs",
    "worker:outbox-dispatcher": "node dist/outbox/outbox-dispatcher.worker.js",
    "outbox:dispatcher:smoke": "node scripts/outbox_dispatcher_smoke.mjs",
    "worker:queue-consumers": "node dist/queue/queue-workers.worker.js",
    "queue:workers:smoke": "node scripts/queue_workers_smoke.mjs",
    "queue:workers:verify": "node scripts/queue_workers_verify.mjs",
    "queue:retry:smoke": "node scripts/queue_retry_smoke.mjs",
    "queue:always-fail:smoke": "node scripts/queue_always_fail_smoke.mjs",
    "queue:retry:verify": "node scripts/queue_retry_verify.mjs",
    "queue:reset:inspect": "node scripts/queue_reset_and_inspect.mjs",
    "queue:dlq:smoke": "node scripts/queue_dlq_smoke.mjs",
    "queue:retention:run": "node scripts/queue_retention_run.mjs",
    "queue:retry-dlq:proof": "node scripts/queue_retry_dlq_proof.mjs",
    "queue:retention:proof": "node scripts/queue_retention_proof.mjs",
    "queue:dlq:list": "node scripts/queue_dlq_list.mjs",
    "queue:dlq:redrive": "node scripts/queue_dlq_redrive.mjs",
    "outbox:crash-recovery:proof": "node scripts/outbox_crash_recovery_proof.mjs",
    "queue:consumer-idempotency:proof": "node scripts/queue_consumer_idempotency_proof.mjs",
    "outbox:multi-instance:proof": "node scripts/outbox_multi_instance_lease_proof.mjs",
    "runtime:lease:smoke": "node scripts/runtime_lease_smoke.mjs",
    "worker:scheduler": "node dist/scheduler/scheduler.worker.js",
    "scheduler:proof": "node scripts/scheduler_cron_discipline_proof.mjs",
    "backpressure:proof": "node scripts/backpressure_global_proof.mjs",
    "ops:runtime:snapshot": "node scripts/ops_runtime_snapshot.mjs",
    "ops:observability:proof": "node scripts/ops_observability_proof.mjs",
    "ops:queue:alerts": "node scripts/ops_queue_alerts.mjs"
  },
  "dependencies": {
    "@bull-board/api": "^6.20.3",
    "@bull-board/express": "^6.20.3",
    "@nest-lab/throttler-storage-redis": "^1.2.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^6.12.0",
    "@sentry/node": "^10.42.0",
    "@sentry/profiling-node": "^10.39.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.70.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "luxon": "^3.7.2",
    "nestjs-pino": "^4.6.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.18.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/helmet": "^0.0.48",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^6.12.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=10 <11"
  }
}
